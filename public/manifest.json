{
  "short_name": "DENPER",
  "name": "DENPER Company",
  "description": "We are a small team of software engineers spread out all across the world, building apps that help and make people better.",
  "dir": "auto",
  "lang": "en",
  "icons": [
    {
      "src": "favicon.svg",
      "type": "image/svg+xml",
      "sizes": "any",
      "purpose": "any"
    },
    {
      "src": "splash.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "screenshots/mobile.avif",
      "sizes": "850x1440",
      "type": "image/avif",
      "platform": "narrow",
      "label": "Mobile screenshot"
    },
    {
      "src": "screenshots/laptop.avif",
      "sizes": "2880x1440",
      "type": "image/avif",
      "platform": "wide",
      "label": "Laptop screenshot"
    }
  ],
  "shortcuts": [
    {
      "name": "Tamil language",
      "short_name": "Tamil",
      "description": "Tamil translation",
      "url": "/?lang=ta",
      "icons": [
        {
          "src": "splash.png",
          "type": "image/png",
          "sizes": "512x512",
          "purpose": "maskable"
        }
      ]
    }
  ],
  "scope": ".",
  "start_url": ".",
  "display_override": ["fullscreen", "minimal-ui"],
  "display": "standalone",
  "theme_color": "#ffffff",
  "background_color": "#ffffff",
  "orientation": "any",
  "categories": ["business"],
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://denper.company/manifest.json"
    }
  ],
  "prefer_related_applications": true
}
